<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="bis_debt.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="5078"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="0" parent="0"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="bis_global_debt" custom_title="0" dock_id="1" table="4,15:mainbis_global_debt"/><dock_state state="000000ff00000000fd00000001000000020000043c000002befc0100000001fb000000160064006f0063006b00420072006f007700730065003101000000000000043c0000013900ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="bis_global_debt" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="85"/><column index="2" value="39"/><column index="3" value="81"/><column index="4" value="83"/><column index="5" value="82"/><column index="6" value="62"/><column index="7" value="93"/><column index="8" value="110"/><column index="9" value="132"/><column index="10" value="117"/><column index="11" value="113"/><column index="12" value="156"/><column index="13" value="93"/><column index="14" value="179"/><column index="15" value="76"/><column index="16" value="179"/><column index="17" value="89"/><column index="18" value="171"/><column index="19" value="115"/><column index="20" value="112"/><column index="21" value="92"/><column index="22" value="90"/><column index="23" value="89"/><column index="24" value="86"/><column index="25" value="86"/><column index="26" value="101"/><column index="27" value="163"/><column index="28" value="265"/><column index="29" value="48"/><column index="30" value="68"/><column index="31" value="80"/><column index="32" value="123"/><column index="33" value="137"/><column index="34" value="187"/><column index="35" value="90"/><column index="36" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="DEBT BY COUNTRY*">SELECT country,
       decade,
		ROUND(SUM(value_billions_usd), 2) AS total_debt_billions,
		ROUND(AVG(value_yoy_pct), 2) AS avg_yoy_growth
FROM bis_global_debt
WHERE country NOT LIKE '%countries%'
GROUP BY country, decade
ORDER BY total_debt_billions DESC;</sql><sql name="GROWTH REGIME*">SELECT 
	growth_regime,
	COUNT(*) AS total_records,
	ROUND(AVG(value_yoy_pct), 2) AS avg_yoy,
	ROUND(AVG(value_qoq_pct), 2) AS avg_qoq
FROM bis_global_debt
GROUP BY growth_regime
ORDER BY avg_yoy DESC;</sql><sql name="ATH COUNT*">SELECT
	country,
	country_region,
	COUNT(*) AS ath_count,
	ROUND(AVG(value_billions_usd), 2) AS avg_debt_billions
FROM bis_global_debt
WHERE is_all_time_high = 1
AND country_region IS NOT NULL
GROUP BY country, country_region
ORDER BY ath_count DESC
LIMIT 10;</sql><sql name="PERIOD*">SELECT
	CASE
		WHEN gfc_period = 1 THEN 'During GFC'
		WHEN covid_period = 1 THEN 'During COVID'
		ELSE 'Normal Period'
	END AS period_type,
	ROUND(AVG(value_yoy_pct), 2) AS avg_yoy,
	ROUND(AVG(value_qoq_pct), 2) AS avg_qoq,
	ROUND(AVG(value_yoy_pct), 2) AS avg_yoy,
	COUNT(*) AS total_records
FROM bis_global_debt
GROUP BY period_type
ORDER BY avg_yoy DESC;
	</sql><current_tab id="3"/></tab_sql></sqlb_project>
